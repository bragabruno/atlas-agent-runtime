{
  "components": {
    "schemas": {
      "AgentRunResponse": {
        "description": "Response for both the start (202) and the poll (200) endpoints.\n\nOn start, ``result``/``error`` are ``null`` and ``status`` is ``running``.\nOn poll, a terminal run carries either ``result`` (succeeded) or ``error``\n(failed); both stay ``null`` while still ``running``.",
        "properties": {
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Explicit failure reason when failed",
            "title": "Error"
          },
          "result": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Final agent answer when succeeded",
            "title": "Result"
          },
          "run_id": {
            "description": "Server-generated run identifier (UUID)",
            "title": "Run Id",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/RunStatus",
            "description": "Current lifecycle status"
          }
        },
        "required": [
          "run_id",
          "status"
        ],
        "title": "AgentRunResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "RunStatus": {
        "description": "API-facing run status returned to polling clients.\n\nProjection of `app.persistence.tables.AgentStatusEnum`:\n``created``/``running`` → ``running``; ``completed`` → ``succeeded``;\n``failed``/``capped`` → ``failed``.",
        "enum": [
          "running",
          "succeeded",
          "failed"
        ],
        "title": "RunStatus",
        "type": "string"
      },
      "StartAgentRunRequest": {
        "additionalProperties": false,
        "description": "Body of ``POST /v1/agent/runs`` — start a run for a named agent.",
        "properties": {
          "agent": {
            "description": "Agent name/id to run (resolves a spec)",
            "minLength": 1,
            "title": "Agent",
            "type": "string"
          },
          "user_message": {
            "description": "The user's input for the run",
            "minLength": 1,
            "title": "User Message",
            "type": "string"
          }
        },
        "required": [
          "agent",
          "user_message"
        ],
        "title": "StartAgentRunRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Trigger surface for the Atlas hand-rolled agent loop: start an agent run and poll it over HTTP (ADR-020).",
    "title": "Atlas Agent Runtime",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/healthz": {
      "get": {
        "description": "Liveness probe — returns a static OK payload.",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Healthz Healthz Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "health"
        ]
      }
    },
    "/v1/agent/runs": {
      "post": {
        "description": "Start a run for ``req.agent`` and return its ``run_id`` (202).",
        "operationId": "start_agent_run_v1_agent_runs_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartAgentRunRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentRunResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Start an agent run",
        "tags": [
          "agent-runs"
        ]
      }
    },
    "/v1/agent/runs/{run_id}": {
      "get": {
        "description": "Poll a run by id; unknown id → 404.",
        "operationId": "get_agent_run_v1_agent_runs__run_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "run_id",
            "required": true,
            "schema": {
              "title": "Run Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentRunResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Poll an agent run",
        "tags": [
          "agent-runs"
        ]
      }
    }
  }
}
